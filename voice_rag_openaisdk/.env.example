# Environment variables for the Voice RAG Chatbot
# Copy this file to .env and fill in your values.
# All services listed here are FREE (free tier).

# ── HuggingFace ─────────────────────────────────────────────
# Get at: https://huggingface.co/settings/tokens  (free account)
HF_TOKEN=hf_your_token_here

# ── Qdrant Cloud ─────────────────────────────────────────────
# Get at: https://cloud.qdrant.io  (free 1 GB tier)
QDRANT_URL=https://xxxx.aws.cloud.qdrant.io:6333
QDRANT_API_KEY=your_qdrant_api_key_here
